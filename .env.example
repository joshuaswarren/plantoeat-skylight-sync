# Copy to .env and fill in. NEVER commit your real .env.
# Values may be plain text or 1Password references (op://vault/item/field).

# The Plan to Eat iCal feed URL (Share Meal Plan -> "All" or "Recipes" variant).
# This URL is an unauthenticated secret — anyone with it can read your meal plan.
PTE_ICAL_URL=op://Shared/Plan to Eat/ical url

# Skylight account (needed to write recipes + the meal plan).
SKYLIGHT_EMAIL=op://Shared/Skylight/username
SKYLIGHT_PASSWORD=op://Shared/Skylight/password
SKYLIGHT_FRAME_ID=000000

# Optional tuning:
# SKYLIGHT_BASE_URL=https://app.ourskylight.com
# SYNC_PAST_DAYS=1
# SYNC_FUTURE_DAYS=21
# SYNC_DEFAULT_SLOT=dinner
# SYNC_ALLOW_DELETE=false
# SYNC_STATE_PATH=/data/state.json
# SYNC_INTERVAL=10800   # container loop interval, seconds (3h)
